# ─── Backend (lido pelo godotenv) ─────────────────────────────────
# Em produção (Render), defina essas variáveis no painel do Render.
# A DATABASE_URL será a Internal Connection String do PostgreSQL do Render.

PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/surveys?sslmode=disable
CORS_ORIGIN=http://localhost:4321
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW=1m
BODY_LIMIT=2

# ─── Frontend (lido pelo Vite — prefixo VITE_ obrigatório) ──────
# Em produção (Netlify), defina VITE_API_URL como a URL do backend no Render.
# Ex: VITE_API_URL=https://researchos-api.onrender.com

VITE_API_URL=http://localhost:8080
